!!!
%html{ lang: 'en', 'data-bs-theme' => 'dark' }
  %head
    %meta{content: "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title AgilePoker
    %meta{content: "width=device-width,initial-scale=1", name: "viewport"}/
    = csrf_meta_tags
    = csp_meta_tag
    = stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload'
    = javascript_include_tag 'application', 'data-turbo-track': 'reload', defer: true
  %body
    %nav.navbar.navbar-expand-lg
      .container-fluid
        = link_to 'Agile Poker', games_path, class: 'navbar-brand'
        %button.navbar-toggler{type: 'button', 'data-bs-toggle' => 'collapse', 'data-bs-target' => '#navbarSupportedContent', 'aria-controls' => 'navbarSupportedContent', 'aria-expanded' => 'false', 'aria-label' => 'Toggle navigation'}
          %span.navbar-toggler-icon
        #navbarSupportedContent.collapse.navbar-collapse
          %ul.navbar-nav.me-auto.mb-2.mb-lg-0
            %li.nav-item= link_to 'Games',           games_path,           class: "nav-link #{'active' if controller_name == 'games'}"
            %li.nav-item= link_to 'Amount of Work',  amount_of_works_path, class: "nav-link #{'active' if controller_name == 'amount_of_works'}"
            %li.nav-item= link_to 'Complexity',      complexities_path,    class: "nav-link #{'active' if controller_name == 'complexities'}"
            %li.nav-item= link_to 'Unknowns / Risks', unknown_risks_path,  class: "nav-link #{'active' if controller_name == 'unknown_risks'}"

    .container.py-3
      = yield
