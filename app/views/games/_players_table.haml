- voters    = players.voters
- observers = players.observers

.card.mb-3
  .card-header Players & Votes
  .table-responsive
    %table.table.table-hover.mb-0
      %thead
        %tr
          %th Player
          %th Complexity
          %th Amount of Work
          %th Unknowns / Risks
          %th Total
          %th.text-primary Fibonacci
          %th Voted?
          %th
      %tbody
        - voters.each do |player|
          %tr
            %td= player.name
            %td= show_player_votes ? player.complexity : '—'
            %td= show_player_votes ? player.amount_of_work : '—'
            %td= show_player_votes ? player.unknown_risk : '—'
            %td= show_player_votes ? player.total_points : '—'
            %td.text-primary= show_player_votes ? player.fibonacci_vote : '—'
            %td
              - if player.voted?
                %span.badge.bg-success-subtle.text-success-emphasis Yes
              - else
                %span.badge.bg-body-tertiary.text-secondary No
            %td.text-end
              = link_to 'Remove', [player.game, player], class: 'btn btn-sm btn-outline-danger', data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }
        - if show_player_votes
          %tr
            %td
              %strong Average
            %td= as_average(voters.sum(:complexity), voters.players_voted.count)
            %td= as_average(voters.sum(:amount_of_work), voters.players_voted.count)
            %td= as_average(voters.sum(:unknown_risk), voters.players_voted.count)
            %td= as_average(voters.sum_total_points, voters.players_voted.count)
            %td.text-primary= as_average(voters.sum_fibonacci_vote, voters.players_voted.count)
            %td
            %td

- if show_player_votes
  .card.mb-3
    .card-header Summary
    .table-responsive
      %table.table.mb-0
        %thead
          %tr
            %th Metric
            %th Player
            %th Points Total
            %th.text-primary Fibonacci
        %tbody
          %tr
            %td
              %span.badge.bg-danger-subtle.text-white Highest
            %td= voters.highest_voter.name
            %td= format_number(voters.highest_voter.total_points)
            %td.text-primary= format_number(voters.highest_voter.fibonacci_vote)
          %tr
            %td
              %span.badge.bg-success-subtle.text-white Lowest
            %td= voters.lowest_voter.name
            %td= format_number(voters.lowest_voter.total_points)
            %td.text-primary= format_number(voters.lowest_voter.fibonacci_vote)

- if observers.any?
  .card.mb-3
    .card-header Observers
    .card-body.py-2
      .d-flex.flex-wrap.gap-2
        - observers.each do |observer|
          .d-flex.align-items-center.gap-2.px-2.py-1.rounded.border.border-secondary-subtle
            = observer.name
            = link_to 'remove', [observer.game, observer], class: 'small text-danger', data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }
